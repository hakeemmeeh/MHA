# Copy to `.env.local` for local development (never commit real secrets).

# Public site URL (use www — matches Vercel production)
NEXT_PUBLIC_SITE_URL=https://www.mha-ss.org

# Supabase — public keys (safe for browser when prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (API routes / server code)
SUPABASE_SERVICE_ROLE_KEY=

# Contact form (Resend)
RESEND_API_KEY=

# Optional override for contact + volunteer notification inbox
CONTACT_NOTIFY_EMAIL=

# Admin dashboard login
# ADMIN_PASSWORD: what you type on the /admin-login screen
# ADMIN_SESSION_SECRET: any long random string (the cookie value) — keep it secret
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=

# Google Analytics 4 — Measurement ID from analytics.google.com (format G-XXXXXXXXXX)
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console — HTML tag verification content value (not the full meta tag)
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Cloudflare Turnstile — spam protection on contact forms (https://dash.cloudflare.com → Turnstile)
NEXT_PUBLIC_TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=
