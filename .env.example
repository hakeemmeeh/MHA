# Copy to `.env.local` for local development (never commit real secrets).

# Supabase — public keys (safe for browser when prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (API routes / server code)
SUPABASE_SERVICE_ROLE_KEY=

# Contact form (Resend)
RESEND_API_KEY=

# Optional override for contact + volunteer notification inbox
CONTACT_NOTIFY_EMAIL=

# Admin dashboard login
# ADMIN_PASSWORD: what you type on the /admin-login screen
# ADMIN_SESSION_SECRET: any long random string (the cookie value) — keep it secret
ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
