# Copy to `.env.local` for local development (never commit real secrets).

# Supabase — public keys (safe for browser when prefixed with NEXT_PUBLIC_)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase — server only (API routes / server code)
SUPABASE_SERVICE_ROLE_KEY=

# Contact form (Resend)
RESEND_API_KEY=

# Optional override for contact notification inbox
CONTACT_NOTIFY_EMAIL=
